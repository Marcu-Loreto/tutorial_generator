# TutorialGen — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── OpenAI API key (required for tutorial generation) ──────────────────────
OPENAI_API_KEY=your_api_key_here

# ── LLM model routing ───────────────────────────────────────────────────────
# Simple tasks: brainstorm, tag extraction, metadata, doc summaries
LLM_SIMPLE_MODEL=MiniMax-2.5

# Medium tasks: PRD, Spec, basic reviewer, language adaptation
LLM_MEDIUM_MODEL=gpt-5.4-nano

# Complex tasks: full tutorial writing, fixer, deep reviewer, troubleshooting
LLM_COMPLEX_MODEL=gpt-5.4-mini

# ── Default AI mode ─────────────────────────────────────────────────────────
# balanced  → use the tier that matches each task's complexity
# economic  → prefer cheaper models (complex → medium, medium → simple)
# quality   → always use the complex model for maximum output quality
LLM_MODE=balanced
